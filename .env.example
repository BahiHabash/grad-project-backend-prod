# ============================================================
# ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file and rename it to:    .env.development.local
# The app loads the env file named:   .env.{NODE_ENV}.local
#
# For development:  .env.development.local
# For testing:      .env.test.local
# For production:   .env.production.local
# ============================================================

# ==================== App Config ====================
NODE_ENV=development
PORT=5050
BASE_URL=http://localhost:5050
API=api/v1

# ==================== Security & Auth ====================
ACCESS_TOKEN_SECRET=your-super-secret-access-key-change-this
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_SECRET=your-super-secret-refresh-key-change-this
REFRESH_TOKEN_TTL=7d
CORS_ORIGIN=http://localhost:3000

# ==================== Database - PostgreSQL ====================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/shalaboka_ai?sslmode=require

# ==================== Email Service ====================
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USER=your-email@gmail.com
MAILER_PASS=your-app-password
MAILER_FROM_ADDRESS=noreply@shalaboka.com

# ==================== Token Lifetimes ====================
EMAIL_VERIFY_TOKEN_TTL=1h
PASSWORD_RESET_TOKEN_TTL=15m
INVITATION_TOKEN_TTL=7d

# ==================== Post-Match Module ====================
# AI Microservice (required — mock server during development)
AI_SERVICE_URL=http://localhost:8001

# LLM — Gemini (comma-separated keys for key rotation)
# GEMINI_API_KEYS=key1,key2,key3
# GEMINI_MODEL=gemini-2.0-flash

# LLM — Groq (fallback provider)
# GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.1-8b-instant

# ==================== Cloudinary Configuration ====================
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_OVERWRITE=false